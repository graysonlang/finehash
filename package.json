{
  "name": "@graysonlang/finehash",
  "version": "1.0.0",
  "description": "Deterministic image placeholder hashes that decode to a blurred preview before the full image loads.",
  "keywords": [
    "hash",
    "thumbnail",
    "placeholder",
    "blurhash",
    "image",
    "lqip"
  ],
  "homepage": "https://github.com/graysonlang/finehash#readme",
  "bugs": {
    "url": "https://github.com/graysonlang/finehash/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/graysonlang/finehash.git"
  },
  "license": "MIT",
  "author": "Grayson Lang",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/finehash.d.ts",
      "default": "./src/finehash.js"
    }
  },
  "main": "./src/finehash.js",
  "types": "./src/finehash.d.ts",
  "files": [
    "src/finehash.js",
    "src/finehash.d.ts"
  ],
  "scripts": {
    "build": "node ./scripts/build.mjs --minify",
    "test": "node ./scripts/test.mjs",
    "deploy-test": "node ./scripts/pack-test.mjs",
    "serve": "node ./scripts/build.mjs --sourcemap --watch --serve --debug-port=9222",
    "dev": "npm run serve -- --proxy --launch",
    "vscode:build": "npm run build -- --vscode",
    "vscode:debug": "npm run serve -- --vscode",
    "gen:samples": "node ./scripts/gen-samples.mjs"
  },
  "devDependencies": {
    "@graysonlang/esp": "^1.6.3",
    "@graysonlang/slim-webp-enc": "^1.2.0",
    "@napi-rs/canvas": "^1.0.2",
    "blurhash": "^2.0.5",
    "esbuild": "^0.28.1",
    "thumbhash": "^0.1.1",
    "typescript": "^5.8.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false
}
