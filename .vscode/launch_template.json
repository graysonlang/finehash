{
  //! Source of truth for .vscode/launch.json — edit this file, not the generated one.
  //!
  //! The esp esbuild runner renders this template into .vscode/launch.json,
  //! substituting the ports derived for this checkout for the {{http}}, {{https}}
  //! and {{debug}} placeholders below. Ports come from the absolute path of
  //! scripts/build.mjs, so every clone and worktree renders its own launch.json
  //! and two of them never collide.
  //!
  //! Lines starting with //! are template-only notes and are stripped on render.
  //! Rendered by `npm install` (prepare) and refreshed whenever the runner serves
  //! or watches. Render it by hand with: npm run sync:launch
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug in Chrome",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:{{http}}",
      "webRoot": "${workspaceFolder}",
      "sourceMapPathOverrides": { "../*": "${workspaceFolder}/*" },
      "preLaunchTask": "debug",
      "postDebugTask": "Kill debug server",
      "sourceMaps": true,
      "outFiles": ["${workspaceFolder}/dist/*.js"]
    }
  ]
}
