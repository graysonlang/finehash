{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug in Chrome",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:8000",
      "webRoot": "${workspaceFolder}",
      "sourceMapPathOverrides": { "../*": "${workspaceFolder}/*" },
      "preLaunchTask": "debug",
      "postDebugTask": "Kill debug server",
      "sourceMaps": true,
      "outFiles": ["${workspaceFolder}/dist/*.js"]
    }
  ]
}
